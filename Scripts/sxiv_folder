#!/bin/sh

# This scripts opens all image files inside a directory with sxiv.
# If a file is provide, all the other files inside it's folder are also opened with sxiv
# Requires gnu core utils dirname, find, xargs and sxiv

if [ -f "$1" ]; then
  first_file="$1"
  working_folder="$(dirname "$1")"
else
  first_file=""
  working_folder="$1"
fi

find "$working_folder" -maxdepth 1 -type f ! -name "$first_file" -print0 | xargs -0 sxiv "$first_file" >/dev/null 2>&1
