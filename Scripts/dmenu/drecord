#!/bin/sh
# Based on Luke Smith's dmenurecord
#
# Usage:
# `$0`: Ask for recording type via dmenu
# `$0 screencast`: Record both audio and screen
# `$0 video`: Record only screen
# `$0 audio`: Record only audio
# `$0 kill`: Kill existing recording
#
# If there is already a running instance, user will be prompted to end it.

OUTPUT_DIR="${DRECORD_SAVEDIR:-"$HOME/Videos"}"
[ -d "$OUTPUT_DIR" ] || mkdir -p "$OUTPUT_DIR"

RECORDPID_FILE="/tmp/recordingpid"

savepid() {
  echo $! >"$RECORDPID_FILE"
}

killrecording() {
  recpid="$(cat $RECORDPID_FILE)"
  # kill with SIGTERM, allowing finishing touches.
  kill -15 "$recpid"
  rm -f "$RECORDPID_FILE"

  # even after SIGTERM, ffmpeg may still run, so SIGKILL it.
  sleep 3
  kill -9 "$recpid"
  exit
}

screencast() {
  ffmpeg \
    -f x11grab \
    -s "$(xdpyinfo | grep dimensions | awk '{print $2;}')" \
    -i "$DISPLAY" \
    -f alsa -i default \
    -c:v libx264 -r 60 \
    -preset superfast -c:a flac \
    "$OUTPUT_DIR/screencast-$(date '+%y%m%d-%H%M-%S').mkv" &
  savepid
}

video() {
  ffmpeg \
    -f x11grab \
    -s "$(xdpyinfo | grep dimensions | awk '{print $2;}')" \
    -i "$DISPLAY" \
    -c:v libx264 -r 60 \
    "$OUTPUT_DIR/video-$(date '+%y%m%d-%H%M-%S').mkv" &
  savepid
}

webcamhidef() {
  ffmpeg \
    -f v4l2 -i /dev/video0 \
    -video_size 1920x1080 \
    "$OUTPUT_DIR/webcam-$(date '+%y%m%d-%H%M-%S').mkv" &
  savepid
}

webcam() {
  ffmpeg \
    -f v4l2 -i /dev/video0 \
    -video_size 640x480 \
    "$OUTPUT_DIR/webcam-$(date '+%y%m%d-%H%M-%S').mkv" &
  savepid
}

audio() {
  ffmpeg \
    -f pulse -i default \
    -c:a flac \
    "$OUTPUT_DIR/audio-$(date '+%y%m%d-%H%M-%S').flac" &
  savepid
}

all() {
  ffmpeg \
    -f x11grab \
    -s "$(xdpyinfo | grep dimensions | awk '{print $2;}')" \
    -i "$DISPLAY" \
    -f pulse -i default \
    $(ffmpeg -sources pulse | awk '{print $1;}' | tail -n +2 | grep -v "\*" | awk '{printf "-f pulse -i %s ", $0;}') \
    -c:v libx264 -r 60 \
    -preset superfast -c:a flac \
    "$OUTPUT_DIR/all-$(date '+%y%m%d-%H%M-%S').mkv" &
  savepid
}

askrecording() {
  asktoend

  op=$(printf "screencast\nvideo\naudio\nwebcam\nwebcam (hi-def)\nall" | dmenu -i -p "Select recording mode:" || exit)
  case "$op" in
  "screencast") screencast ;;
  "audio") audio ;;
  "video") video ;;
  "webcam") webcam ;;
  "webcam (hi-def)") webcamhidef ;;
  "all") all ;;
  esac
}

asktoend() {
  if [ -f "$RECORDPID_FILE" ]; then
    response=$(printf "No\nYes" | dmenu -i -p "Recording still active. End recording?" || return)
    [ "$response" = "Yes" ] && killrecording
  fi
}

case "$1" in
"screencast") screencast ;;
"audio") audio ;;
"video") video ;;
"kill") killrecording ;;
*) askrecording ;;
esac
